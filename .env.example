# Copiá este archivo a .env.local y completá con las credenciales de TU proyecto
# de Supabase de desarrollo (nunca las de producción).
#
#   cp .env.example .env.local
#
# Dónde conseguir estos valores: dashboard de Supabase del proyecto de dev
# → Project Settings → API → "Project URL" y "anon / public" key.
#
# Sin estas variables, la app no arranca (ver src/integrations/supabase/client.ts) —
# es intencional, para que nunca se caiga por default en el proyecto de producción.

VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
